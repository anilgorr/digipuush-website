# Resend API key used by the /api/contact route to email contact-form leads.
# Get one at https://resend.com. Set this in Netlify → Site settings →
# Environment variables for production (setting it only in Replit does nothing
# in the deployed site).
RESEND_API_KEY=

# Optional. The "from" address for lead emails. Requires a verified domain in
# Resend. Defaults to "Digipuush Website <onboarding@resend.dev>" if unset.
# Example: Digipuush Website <leads@digipuush.com>
CONTACT_FROM_EMAIL=
